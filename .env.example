# Runtime / deployment environment variables for Batik FastAPI

# Image to run (set by CI as GHCR image tag); optional for local use
FASTAPI_IMAGE=batik-fastapi:local

# Paths on the VPS that will be mounted into the container (host paths)
BATIK_MODELS_DIR=/opt/models
BATIK_CHECKPOINTS_DIR=/opt/checkpoints
BATIK_DATA_DIR=/opt/data

# Service port the container listens on (container side)
PORT=8000

# Application flags
DEBUG=false
APP_VERSION=1.0.0

# /app/models/convnext_feature_extractor.pt
BATIK_SEARCH_FEATURE_EXTRACTOR_WEIGHTS=